# Copiez ce fichier en .env et remplissez les valeurs.
# Ne commitez jamais .env (déjà dans .gitignore).

# Mailchimp (compte → Extras → Clés API)
# Le préfixe serveur est dans l'URL de votre compte (ex: us21 dans https://us21.admin.mailchimp.com)
# Optionnel : créer des champs de fusion PHONE, ORG, PROGRAM, MESSAGE dans Audience → Paramètres → Champs de fusion
MAILCHIMP_API_KEY=votre_cle_api
MAILCHIMP_SERVER=us21
MAILCHIMP_LIST_ID=id_de_votre_liste

# Odoo (CRM)
# Avec 2FA activée : créez une clé API dans Odoo (Profil → Préférences / Compte → Clés API) et mettez-la dans ODOO_API_KEY
ODOO_URL=https://votre-instance.odoo.com
ODOO_DB=votre_base
ODOO_USER=email@exemple.com
ODOO_PASSWORD=votre_mot_de_passe
ODOO_API_KEY=
# Optionnel : placer les nouveaux leads dans une étape précise (ex. "1-Nouvelle demande arrivée")
# ID = nombre dans l’URL quand vous ouvrez l’étape : .../web#id=XX&model=crm.stage
# ODOO_STAGE_ID=
# ODOO_TEAM_ID= (vide = lead sans équipe, visible à toutes les équipes)
# Remplir les champs École/Organisation et Programme sur la fiche lead (pas seulement dans les notes) :
# Noms techniques = voir GET http://localhost:3000/api/odoo/lead-fields (chercher "string" du champ)
# ODOO_FIELD_ORGANISATION=
# ODOO_FIELD_PROGRAMME=

# Port du serveur (optionnel, défaut 3000)
PORT=3000
